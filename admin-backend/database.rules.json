{
  "rules": {
    "devices": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      "$device_id": {
        ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
        ".write": "auth != null"
      }
    },
    "deviceSecrets": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      "$device_id": {
        ".write": "auth != null"
      }
    },
    "authorizedAdmins": {
      ".read": "auth != null && root.child('authorizedAdminsUids').child(auth.uid).exists()",
      ".write": "false"
    },
    "authorizedAdminsUids": {
      ".read": "auth != null && root.child('authorizedAdminsUids').child(auth.uid).exists()",
      ".write": "false"
    },
    "commandLog": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      ".write": "false"
    },
    "archivedDevices": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())"
    },
    "groups": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())"
    },
    "globalSettings": {
      ".read": true,
      ".write": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())"
    },
    "storeApps": {
      ".read": true,
      ".write": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())"
    }
  }
}
